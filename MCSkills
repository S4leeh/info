<!DOCTYPE html>
<html lang="ar" dir="rtl">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>S4leeh Minecraft Challenge</title>
    <link href="https://fonts.googleapis.com/css2?family=Cairo:wght@400;700;900&display=swap" rel="stylesheet">
    <style>
        :root {
            --bg-color: #050505; /* خلفية داكنة جداً */
            --widget-bg: #111111; /* خلفية الجدول */
            
            /* ألوان المتسابقين */
            --khalid-color: #00bfff; /* أزرق نيون */
            --raheeb-color: #00ff44; /* أخضر زمردي */
            
            --step-bg: #222; /* لون المربعات الفارغة */
            --text-main: #ffffff;
            --border-color: #333;
        }

        body {
            font-family: 'Cairo', sans-serif;
            background-color: var(--bg-color);
            color: var(--text-main);
            margin: 0;
            display: flex;
            flex-direction: column;
            align-items: center;
            height: 100vh;
            overflow: hidden;
        }

        /* منطقة العرض للبث */
        .stream-display {
            flex: 1;
            width: 100%;
            display: flex;
            flex-direction: column;
            justify-content: center;
            align-items: center;
            padding: 20px;
        }

        /* إطار الجدول المدمج */
        .arena-widget {
            width: 90%;
            max-width: 850px;
            background: var(--widget-bg);
            border-radius: 20px;
            padding: 0;
            border: 3px solid var(--border-color);
            box-shadow: 0 15px 40px rgba(0,0,0,0.7);
            overflow: hidden;
            position: relative; /* مهم جداً لتحديد موقع رسالة الفوز */
        }

        /* عنوان التحدي */
        .challenge-title {
            background: rgba(255, 255, 255, 0.03);
            border-bottom: 2px solid var(--border-color);
            padding: 25px;
            text-align: center;
            margin: 0;
            font-size: 2.2rem;
            font-weight: 900;
            color: var(--text-main);
            text-shadow: 0 0 15px rgba(255,255,255,0.3);
        }

        /* محتوى الجدول */
        .arena-content {
            padding: 40px;
        }

        .player-row {
            display: flex;
            align-items: center;
            margin-bottom: 30px;
        }
        .player-row:last-child { margin-bottom: 0; }

        .name-tag {
            width: 140px;
            font-size: 1.7rem;
            font-weight: 700;
            margin-left: 20px;
        }

        .steps-wrapper {
            flex: 1;
            display: grid;
            grid-template-columns: repeat(4, 1fr);
            gap: 15px;
        }

        .step-box {
            height: 45px;
            background: var(--step-bg);
            border-radius: 10px;
            transition: all 0.5s cubic-bezier(0.175, 0.885, 0.32, 1.275);
            border: 1px solid rgba(255,255,255,0.05);
        }

        /* حالات التفعيل */
        .active-khalid { background: var(--khalid-color); box-shadow: 0 0 25px var(--khalid-color); border: none; }
        .active-raheeb { background: var(--raheeb-color); box-shadow: 0 0 25px var(--raheeb-color); border: none; }

        /* طبقة رسالة النتيجة في المنتصف */
        #result-overlay {
            position: absolute;
            top: 0;
            left: 0;
            width: 100%;
            height: 100%;
            background-color: rgba(0, 0, 0, 0.9); /* خلفية داكنة نصف شفافة */
            display: flex;
            justify-content: center;
            align-items: center;
            z-index: 10;
            opacity: 0; /* مخفية في البداية */
            visibility: hidden;
            transition: all 0.5s ease;
        }

        #result-overlay.show {
            opacity: 1;
            visibility: visible;
        }

        #result-text {
            font-size: 4rem;
            font-weight: 900;
            text-align: center;
            padding: 20px;
        }

        /* لوحة التحكم (للقص في OBS) */
        .control-panel {
            width: 100%;
            background: #000;
            padding: 20px;
            display: flex;
            justify-content: center;
            gap: 25px;
            border-top: 5px solid #222;
        }

        .admin-btn {
            padding: 15px 35px;
            font-family: 'Cairo', sans-serif;
            font-size: 1.1rem;
            cursor: pointer;
            border: none;
            border-radius: 12px;
            font-weight: bold;
            transition: 0.3s;
        }

        .btn-k { background: var(--khalid-color); color: #000; }
        .btn-r { background: var(--raheeb-color); color: #000; }
        .btn-reset { background: #333; color: #fff; }

        .admin-btn:hover { transform: translateY(-3px); opacity: 0.9; }
        .admin-btn:active { transform: scale(0.97); }
    </style>
</head>
<body>

    <div class="stream-display">
        
        <div class="arena-widget">
            <h1 class="challenge-title">من الأكثر مهارة في ماين كرافت؟</h1>
            
            <div class="arena-content">
                <div class="player-row">
                    <div class="name-tag" style="color: var(--khalid-color);">خالد</div>
                    <div class="steps-wrapper" id="khalid-track">
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                    </div>
                </div>

                <div class="player-row">
                    <div class="name-tag" style="color: var(--raheeb-color);">رهيب</div>
                    <div class="steps-wrapper" id="raheeb-track">
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                        <div class="step-box"></div>
                    </div>
                </div>
            </div>

            <div id="result-overlay">
                <div id="result-text"></div>
            </div>
        </div>
    </div>

    <div class="control-panel">
        <button class="admin-btn btn-k" onclick="addPoint('khalid')">+ نقطة لـ خالد</button>
        <button class="admin-btn btn-r" onclick="addPoint('raheeb')">+ نقطة لـ رهيب</button>
        <button class="admin-btn btn-reset" onclick="resetChallenge()">إعادة تعيين</button>
    </div>

    <script>
        let scores = { khalid: 0, raheeb: 0 };
        let gameFinished = false;

        function addPoint(player) {
            if (gameFinished) return;

            scores[player]++;
            updateDisplay();
            checkRules();
        }

        function updateDisplay() {
            // تحديث مربعات خالد
            const kSteps = document.querySelectorAll('#khalid-track .step-box');
            kSteps.forEach((box, i) => {
                if (i < scores.khalid) box.classList.add('active-khalid');
                else box.classList.remove('active-khalid');
            });

            // تحديث مربعات رهيب
            const rSteps = document.querySelectorAll('#raheeb-track .step-box');
            rSteps.forEach((box, i) => {
                if (i < scores.raheeb) box.classList.add('active-raheeb');
                else box.classList.remove('active-raheeb');
            });
        }

        function checkRules() {
            const overlay = document.getElementById('result-overlay');
            const text = document.getElementById('result-text');
            let message = "";
            let color = "";

            // 1. قاعدة التعادل (2-2)
            if (scores.khalid === 2 && scores.raheeb === 2) {
                message = "تعادل عادل! ⚔️";
                color = "#aaaaaa";
                gameFinished = true;
            } 
            // 2. قاعدة فوز خالد (الوصول لـ 3)
            else if (scores.khalid === 3) {
                message = "خالد هو الأمهر! 👑";
                color = "var(--khalid-color)";
                gameFinished = true;
            }
            // 3. قاعدة فوز رهيب (الوصول لـ 3)
            else if (scores.raheeb === 3) {
                message = "رهيب هو الأمهر! 👑";
                color = "var(--raheeb-color)";
                gameFinished = true;
            }

            if (gameFinished) {
                text.innerText = message;
                text.style.color = color;
                overlay.classList.add('show');
            }
        }

        function resetChallenge() {
            scores = { khalid: 0, raheeb: 0 };
            gameFinished = false;
            document.getElementById('result-overlay').classList.remove('show');
            updateDisplay();
        }
    </script>
</body>
</html>
